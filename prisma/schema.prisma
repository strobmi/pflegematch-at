generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPERADMIN
  VERMITTLER_ADMIN
  PFLEGER
  KUNDE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MatchStatus {
  PROPOSED
  PENDING
  ACCEPTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PflegestufeLevel {
  STUFE_1
  STUFE_2
  STUFE_3
  STUFE_4
  STUFE_5
}

enum AvailabilityType {
  FULL_TIME
  PART_TIME
  HOURLY
  LIVE_IN
}

// ─────────────────────────────────────────────
// TENANT (Vermittler-Firma)
// ─────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  email     String
  phone     String?
  address   String?
  logoUrl   String?
  status    TenantStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships       TenantMembership[]
  caregiverProfiles CaregiverProfile[]
  clientProfiles    ClientProfile[]
  matches           Match[]
  matchRequests     MatchRequest[]

  @@index([slug])
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  avatarUrl     String?
  role          Role      @default(KUNDE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships      TenantMembership[]
  sessions         Session[]
  accounts         Account[]
  caregiverProfile CaregiverProfile?
  clientProfile    ClientProfile?

  @@index([email])
}

// ─────────────────────────────────────────────
// NEXTAUTH ADAPTER TABELLEN
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// TENANT MEMBERSHIP
// ─────────────────────────────────────────────

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// CAREGIVER PROFILE (Pfleger)
// ─────────────────────────────────────────────

model CaregiverProfile {
  id             String             @id @default(cuid())
  userId         String             @unique
  tenantId       String
  bio            String?            @db.Text
  qualifications String[]
  skills         String[]
  languages      String[]
  pflegestufe    PflegestufeLevel[]
  availability   AvailabilityType   @default(PART_TIME)
  locationCity   String?
  locationState  String?
  travelRadius   Int?
  hourlyRate     Decimal?           @db.Decimal(8, 2)
  isActive       Boolean            @default(true)

  backgroundChecked Boolean  @default(false)
  certificatesUrls  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchesAsPfleger Match[] @relation("PflegerMatches")

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// CLIENT PROFILE (Klient / Kunden)
// ─────────────────────────────────────────────

model ClientProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  tenantId             String
  careNeedsDescription String?           @db.Text
  pflegegeldStufe      PflegestufeLevel?
  requiredSkills       String[]
  preferredLanguages   String[]
  preferredSchedule    AvailabilityType?
  locationCity         String?
  locationState        String?
  locationPostal       String?

  emergencyContactName  String?
  emergencyContactPhone String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchesAsClient Match[]     @relation("ClientMatches")
  matchRequests   MatchRequest[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────────

model Match {
  id                 String      @id @default(cuid())
  tenantId           String
  caregiverProfileId String
  clientProfileId    String
  status             MatchStatus @default(PROPOSED)
  score              Int?
  notes              String?     @db.Text
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  caregiverProfile CaregiverProfile @relation("PflegerMatches", fields: [caregiverProfileId], references: [id])
  clientProfile    ClientProfile    @relation("ClientMatches", fields: [clientProfileId], references: [id])

  @@index([tenantId])
  @@index([caregiverProfileId])
  @@index([clientProfileId])
}

// ─────────────────────────────────────────────
// MATCH REQUEST (eingehende Anfragen)
// ─────────────────────────────────────────────

model MatchRequest {
  id              String            @id @default(cuid())
  tenantId        String
  clientProfileId String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  careNeedsRaw    String?           @db.Text
  pflegegeldStufe PflegestufeLevel?
  preferredStart  DateTime?
  notes           String?           @db.Text
  isProcessed     Boolean           @default(false)
  createdAt       DateTime          @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  clientProfile ClientProfile? @relation(fields: [clientProfileId], references: [id])

  @@index([tenantId])
}
