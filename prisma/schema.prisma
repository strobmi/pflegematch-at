generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPERADMIN
  VERMITTLER_ADMIN
  PFLEGER
  KUNDE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MatchStatus {
  PROPOSED
  PENDING
  ACCEPTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PflegestufeLevel {
  STUFE_1
  STUFE_2
  STUFE_3
  STUFE_4
  STUFE_5
}

enum AvailabilityType {
  FULL_TIME
  PART_TIME
  HOURLY
  LIVE_IN
}

enum CaregiverType {
  EMPLOYED   // bei Vermittler angestellt/registriert
  FREELANCE  // direkt auf Plattform (vorbereitet, noch nicht aktiv)
}

enum AvailabilityStatus {
  AVAILABLE
  ON_ASSIGNMENT
  VACATION
  BLOCKED
}

enum ProvisionStatus {
  PENDING
  INVOICED
  PAID
}

enum ContractStatus {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum ReviewTarget {
  CAREGIVER
  VERMITTLER
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum ProposalStatus {
  OPEN
  SELECTED
  DECLINED
}

enum ProposedByRole {
  PFLEGER
  VERMITTLER
  KUNDE
}

enum ClosedReason {
  KEIN_INTERESSE
  ANDERWEITIG_VERSORGT
  KEIN_PFLEGER
  NICHT_ERREICHBAR
  SONSTIGES
}

// ─────────────────────────────────────────────
// TENANT (Vermittler-Firma)
// ─────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  email     String
  phone     String?
  address   String?
  logoUrl   String?
  status    TenantStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  isPlatform        Boolean   @default(false)   // true = pflegematch.at selbst (genau 1x)
  provisionPercent  Decimal?  @db.Decimal(5, 2) // Legacy: %, bleibt für Übergangszeit
  defaultMatchFee   Decimal?  @db.Decimal(8, 2) // Standard-Matchgebühr (€, einmalig)
  defaultMonthlyFee Decimal?  @db.Decimal(8, 2) // Standard-Monatspauschale (€, pro aktivem Match)
  lastAssignedAt    DateTime?                   // Score-Zuweisung: wann zuletzt eine Anfrage zugewiesen wurde

  memberships           TenantMembership[]
  caregiverProfiles     CaregiverProfile[]
  clientProfiles        ClientProfile[]
  matches               Match[]
  matchRequests         MatchRequest[]
  caregiverAvailabilities CaregiverAvailability[]
  videoMeetings         VideoMeeting[]
  meetingProposals      MeetingProposal[]
  inviteTokens          InviteToken[]
  contracts             Contract[]

  @@index([slug])
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  avatarUrl     String?
  role          Role      @default(KUNDE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lastAssignedAt  DateTime? // Round-Robin: wann zuletzt eine Anfrage zugewiesen wurde
  lastLoginAt     DateTime? // gesetzt beim Login via Credentials

  memberships        TenantMembership[]
  caregiverProfile   CaregiverProfile?
  clientProfile      ClientProfile?
  reviewsWritten     Review[]            @relation("ReviewsWritten")
  assignedRequests   MatchRequest[]      @relation("AssignedRequests")
  processedRequests  MatchRequest[]      @relation("ProcessedRequests")
  emailChangeTokens  EmailChangeToken[]

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

model EmailChangeToken {
  id        String    @id @default(cuid())
  userId    String
  newEmail  String
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────────────────
// TENANT MEMBERSHIP
// ─────────────────────────────────────────────

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// CAREGIVER PROFILE (Pfleger)
// ─────────────────────────────────────────────

model CaregiverProfile {
  id                String           @id @default(cuid())
  userId            String           @unique
  tenantId          String
  type              CaregiverType    @default(EMPLOYED)
  bio               String?          @db.Text
  qualifications    String[]
  skills            String[]
  languages         String[]
  pflegestufe       PflegestufeLevel[]
  availability      AvailabilityType @default(PART_TIME)
  locationCity      String?
  locationState     String?
  travelRadius      Int?
  hourlyRate        Decimal?         @db.Decimal(8, 2)
  isActive          Boolean          @default(true)
  isPlatformVisible Boolean          @default(false) // Cross-Tenant Matching Opt-In
  averageRating     Float?           // denormalisiert, bei neuem Review aktualisiert

  backgroundChecked Boolean  @default(false)
  certificatesUrls  String[]

  addressStreet     String?  // Wohnadresse
  addressPostal     String?
  addressCity       String?
  addressCountry    String?
  iban              String?  // Bankverbindung
  bic               String?
  bankAccountHolder String?
  referredBy        String?  // Empfehlung / Vermittlung durch

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchesAsPfleger Match[]                  @relation("PflegerMatches")
  availabilities   CaregiverAvailability[]
  directRequests   MatchRequest[]           @relation("DirectRequests")
  contracts        Contract[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// CLIENT PROFILE (Klient / Kunden)
// ─────────────────────────────────────────────

model ClientProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  tenantId             String
  careNeedsDescription String?           @db.Text
  pflegegeldStufe      PflegestufeLevel?
  requiredSkills       String[]
  preferredLanguages   String[]
  preferredSchedule    AvailabilityType?
  locationCity         String?
  locationState        String?
  locationPostal       String?

  emergencyContactName  String?
  emergencyContactPhone String?

  addressStreet    String?  // Wohnadresse
  addressCountry   String?
  iban             String?  // Bankverbindung
  bic              String?
  bankAccountHolder String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchesAsClient Match[]     @relation("ClientMatches")
  matchRequests   MatchRequest[]
  contracts       Contract[]

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────────

model Match {
  id                 String      @id @default(cuid())
  tenantId           String
  caregiverProfileId String
  clientProfileId    String
  status             MatchStatus @default(PROPOSED)
  score              Int?
  notes              String?     @db.Text
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  provisionAmount  Decimal?        @db.Decimal(8, 2) // = Contract.monthlyFeeAmount (Snapshot)
  provisionStatus  ProvisionStatus @default(PENDING)
  matchFeeAmount   Decimal?        @db.Decimal(8, 2) // = Contract.matchFeeAmount (Snapshot, einmalig)

  // Kennenlerngespräch-Bestätigung
  caregiverConfirmed   Boolean?
  caregiverConfirmedAt DateTime?
  clientConfirmed      Boolean?
  clientConfirmedAt    DateTime?

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  caregiverProfile CaregiverProfile @relation("PflegerMatches", fields: [caregiverProfileId], references: [id], onDelete: Cascade)
  clientProfile    ClientProfile    @relation("ClientMatches", fields: [clientProfileId], references: [id], onDelete: Cascade)
  availabilities    CaregiverAvailability[]
  reviews           Review[]
  videoMeetings     VideoMeeting[]
  meetingProposals  MeetingProposal[]
  contract          Contract?

  @@index([tenantId])
  @@index([caregiverProfileId])
  @@index([clientProfileId])
}

// ─────────────────────────────────────────────
// MATCH REQUEST (eingehende Anfragen)
// ─────────────────────────────────────────────

model MatchRequest {
  id              String            @id @default(cuid())
  tenantId        String            // platform tenant ID bis zur Zuweisung an einen Vermittler
  clientProfileId String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  careNeedsRaw    String?           @db.Text
  pflegegeldStufe PflegestufeLevel?
  preferredStart  DateTime?
  notes           String?           @db.Text
  isProcessed     Boolean           @default(false)
  closedReason    ClosedReason?
  closedNote      String?           @db.Text
  createdAt       DateTime          @default(now())

  assignedToUserId   String? // Round-Robin: zugewiesener Vermittler-Admin
  processedByUserId  String? // wer die Anfrage abgeschlossen hat

  targetCaregiverId  String? // Direktanfrage an eine bestimmte Pflegekraft
  targetCaregiver    CaregiverProfile? @relation("DirectRequests", fields: [targetCaregiverId], references: [id])

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  clientProfile ClientProfile? @relation(fields: [clientProfileId], references: [id])
  assignedTo    User?          @relation("AssignedRequests",   fields: [assignedToUserId],  references: [id])
  processedBy   User?          @relation("ProcessedRequests",  fields: [processedByUserId], references: [id])

  @@index([tenantId])
  @@index([assignedToUserId])
  @@index([targetCaregiverId])
}

// ─────────────────────────────────────────────
// INVITE TOKEN (Team-Einladungen)
// ─────────────────────────────────────────────

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  tenantId  String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
}

// ─────────────────────────────────────────────
// CAREGIVER AVAILABILITY (Verfügbarkeitskalender)
// ─────────────────────────────────────────────

model CaregiverAvailability {
  id                 String             @id @default(cuid())
  caregiverProfileId String
  tenantId           String
  startDate          DateTime
  endDate            DateTime?
  status             AvailabilityStatus
  matchId            String?            // gesetzt wenn ON_ASSIGNMENT
  notes              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  caregiverProfile CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  match            Match?           @relation(fields: [matchId], references: [id])

  @@index([caregiverProfileId])
  @@index([tenantId])
  @@index([startDate, endDate])
}

// ─────────────────────────────────────────────
// REVIEW (Bewertungen)
// ─────────────────────────────────────────────

model Review {
  id         String       @id @default(cuid())
  matchId    String
  authorId   String
  targetType ReviewTarget
  targetId   String       // CaregiverProfile.id oder User.id
  rating     Int          // 1–5
  comment    String?      @db.Text
  isPublic   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  match  Match @relation(fields: [matchId], references: [id])
  author User  @relation("ReviewsWritten", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([targetId])
}

// ─────────────────────────────────────────────
// VIDEO MEETING (Whereby Videoanrufe)
// ─────────────────────────────────────────────

model VideoMeeting {
  id               String        @id @default(cuid())
  tenantId         String
  matchId          String
  wherebyMeetingId String        @unique
  roomUrl          String        // Teilnehmer-Link (Kunde + Pfleger)
  hostRoomUrl      String?       // Host-Link (NUR Vermittler, falls verfügbar)
  scheduledAt      DateTime
  durationMin      Int           @default(30)
  status           MeetingStatus @default(SCHEDULED)
  cancelledAt      DateTime?
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([matchId])
  @@index([scheduledAt])
}

// ─────────────────────────────────────────────
// MEETING PROPOSAL (Terminvorschläge)
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// CONTRACT (Betreuungsvertrag)
// ─────────────────────────────────────────────

model Contract {
  id                 String         @id @default(cuid())
  matchId            String         @unique
  tenantId           String
  caregiverProfileId String
  clientProfileId    String

  contractNumber          String?   // Interne Vermittler-Referenznummer
  contractNumberCaregiver String?   // Referenznummer für Pflegekraft (z.B. aus deren System)
  contractNumberClient    String?   // Referenznummer für Klient (z.B. aus deren System)

  startDate          DateTime
  endDate            DateTime?      // null = unbefristet
  noticePeriodDays   Int            @default(14)
  notes              String?        @db.Text

  // Tatsächlich verrechnet (Snapshot bei Vertragsabschluss, Vermittler kann anpassen)
  // Vorausgefüllt aus Tenant.defaultMatchFee / defaultMonthlyFee
  matchFeeAmount     Decimal?       @db.Decimal(8, 2)  // einmalig
  monthlyFeeAmount   Decimal?       @db.Decimal(8, 2)  // laufend pro Monat

  status             ContractStatus @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  match            Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  caregiverProfile CaregiverProfile @relation(fields: [caregiverProfileId], references: [id])
  clientProfile    ClientProfile    @relation(fields: [clientProfileId], references: [id])

  @@index([tenantId])
  @@index([caregiverProfileId])
  @@index([clientProfileId])
}

model MeetingProposal {
  id          String         @id @default(cuid())
  tenantId    String
  matchId     String
  proposedAt  DateTime
  durationMin Int            @default(30)
  status      ProposalStatus @default(OPEN)
  proposedBy  ProposedByRole
  createdAt   DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([tenantId])
}
